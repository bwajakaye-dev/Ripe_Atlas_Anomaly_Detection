# Pipeline output — CSVs are large/regenerable, keep them out
output/*.csv

# PNGs are committed so they display in the README on GitHub
# (output/*.png is intentionally NOT ignored)

# Quarto render cache — not needed in the repo
.quarto/
*_files/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.env
.venv
env/
venv/

# Sensitive files — never commit these
kc-download-recovery-codes.txt
*.key
*.pem
secrets.txt

# OS noise
.DS_Store
Thumbs.db

/.quarto/
**/*.quarto_ipynb
